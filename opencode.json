{
  "$schema": "https://opencode.ai/config.json",
  "model": "litellm/minimax-m2.7:cloud",
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM Gateway (Dark Gravity)",
      "options": {
        "baseURL": "http://litellm.llm-apps.svc.cluster.local:4000/v1"
      },
      "models": {
        "minimax-m2.7:cloud": {
          "name": "Minimax-M2.7 (via LiteLLM)"
        }

      }
    }
  },
  "mcp": {
    "factory": {
      "type": "remote",
      "url": "http://mcp-server.agents.svc.cluster.local:8200/sse",
      "enabled": true
    }
  },
  "permission": {
    "bash": "allow",
    "edit": "allow",
    "write": "allow",
    "webfetch": "deny",
    "websearch": "deny",
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "factory_*": "allow"
  }
}
